{
  "name": "@alyt/plugin-vercel",
  "version": "0.1.0",
  "description": "Vercel Analytics plugin for alyt",
  "keywords": [
    "analytics",
    "vercel",
    "typescript",
    "plugin",
    "event-tracking"
  ],
  "type": "module",
  "exports": {
    ".": "./build/index.js",
    "./react": "./build/react/index.js"
  },
