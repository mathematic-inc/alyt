{
  "name": "@alyt/plugin-amplitude",
  "version": "0.1.1",
  "description": "Amplitude plugin for alyt",
  "keywords": [
    "analytics",
    "amplitude",
    "typescript",
    "plugin",
    "event-tracking"
  ],
  "type": "module",
  "exports": {
    ".": "./build/index.js",
    "./react": "./build/react/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.lib.json --noEmit"
  },
  "dependencies": {
    "@alyt/core": "workspace:*"
  },
  "peerDependencies": {
    "@amplitude/analytics-browser": ">=2",
    "next": ">=14",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@amplitude/analytics-browser": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "author": "Mathematic Inc",
  "license": "Apache-2.0",
  "devDependencies": {
    "@amplitude/analytics-browser": "^2.36.3",
    "@types/react": "19.2.14",
    "next": "16.1.6",
    "react": "19.2.4",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mathematic-inc/alyt.git",
    "directory": "packages/plugin-amplitude"
  }
}
