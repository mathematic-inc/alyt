{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "initial-version": "0.1.0",
  "packages": {
    "packages/core": {
      "release-type": "node",
      "include-component-in-tag": false
    },
    "packages/react": {
      "release-type": "node"
    },
    "packages/codegen": {
      "release-type": "node"
    },
    "packages/plugin-ga": {
      "release-type": "node"
    },
    "packages/plugin-posthog": {
      "release-type": "node"
    },
    "packages/plugin-mixpanel": {
      "release-type": "node"
    },
    "packages/plugin-amplitude": {
      "release-type": "node"
    },
    "packages/plugin-plausible": {
      "release-type": "node"
    },
    "packages/plugin-vercel": {
      "release-type": "node"
    }
  },
  "plugins": ["sentence-case"]
}
